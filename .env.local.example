# Server
PORT=3000
HOST=localhost

# Public base URL used when building package access URLs returned by MCP tools
# Should be the externally-reachable origin (e.g. https://talonpress.example.com)
PUBLIC_BASE_URL=http://localhost:3000

# Storage path — defaults to ./.storage relative to cwd if left blank
STORAGE_DIR_PATH=

# Optional: set to enable auth gating on management views and the MCP endpoint.
# When set, the /auth page and session cookies are activated.
TALONPRESS_SHARED_SECRET=

# Session cookie TTL in seconds (default: 3600 = 1 hour)
AUTH_SESSION_TTL=3600
